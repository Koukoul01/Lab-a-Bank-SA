        <div class="floating-sticker s2" style="position: absolute; width: 80px; height: 80px; left: 30px; top: 20px; animation-delay: -2s; background: radial-gradient(circle, rgba(255,0,200,0.5), rgba(0,200,255,0.2)); border-color: #ff66cc; border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; animation: morph 8s infinite ease-in-out; backdrop-filter: blur(8px); border: 1px solid cyan;"></div>
    </div>
    
    <div class="container">
        <!-- En-tête avec logo -->
        <div class="hero">
            <div class="logo-wrapper">
                <img src="https://i.postimg.cc/rpSQ7TFV/Logopit-1769736947761.png" alt="Logo CEG - Club Entrepreneurial des Génies">
            </div>
            <h1>CEG</h1>
            <div class="sub">Club Entrepreneurial des Génies</div>
            <div style="margin-top: 0.5rem; font-size: 1rem; background: rgba(0,0,0,0.4); backdrop-filter: blur(4px); padding: 0.3rem 1rem; border-radius: 30px;">
                <i class="fas fa-brain"></i> Espace de formation intellectuelle & initiation à la technologie
            </div>
        </div>

        <!-- BANNIÈRE TEST (identifiants) -->
        <div style="display: flex; justify-content: center;">
            <div class="test-banner">
                <i class="fas fa-flask"></i>
                <span><strong>Période de test</strong> — Identifiants de connexion provisoires :</span>
                <span><i class="fas fa-envelope"></i> <strong>eseye@ceg.ht</strong></span>
                <span><i class="fas fa-lock"></i> <strong>eseye01</strong></span>
                <span>(utilisables partout où une connexion est requise)</span>
            </div>
        </div>

        <!-- BOUTONS EN HAUT: ESPACE ACCUEIL + ASSISTANT IA -->
        <div class="top-button-wrapper">
            <div class="neon-btn">
                <a href="https://accueilceg.netlify.app/" target="_blank" rel="noopener noreferrer">
                    <i class="fas fa-children"></i> Entrée 👈
                </a>
            </div>
            <div class="neon-btn" id="openAIBtn">
                <i class="fas fa-robot"></i> Assistant IA
            </div>
        </div>

        <!-- SECTION MÉTHODOLOGIE FORMATION WEB SUR MOBILE -->
