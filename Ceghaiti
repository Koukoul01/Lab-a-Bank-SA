    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getDatabase, ref, push, set, get, child, update, remove } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-database.js";
        
        const firebaseConfig = {
            apiKey: "AIzaSyDKN5XbeM_7hqFevPe332xszyopy85tfZg",
            authDomain: "bank-pam-7e73b.firebaseapp.com",
            databaseURL: "https://bank-pam-7e73b-default-rtdb.firebaseio.com",
            projectId: "bank-pam-7e73b",
            storageBucket: "bank-pam-7e73b.firebasestorage.app",
            messagingSenderId: "540262089578",
            appId: "1:540262089578:web:6d44c496ba2cc907379b13",
            measurementId: "G-N6F44MTRPH"
        };
        
        const app = initializeApp(firebaseConfig);
        const database = getDatabase(app);
        
        // Éléments DOM
        const modal = document.getElementById('aiModal');
        const openBtn = document.getElementById('openAIBtn');
        const closeBtn = document.getElementById('closeModalBtn');
        const chatMessagesDiv = document.getElementById('chatMessages');
        const userInput = document.getElementById('userInput');
        const sendBtn = document.getElementById('sendMsgBtn');
        const clearChatModalBtn = document.getElementById('clearChatModalBtn');
        
        const STORAGE_KEY = 'ceg_conversation';
        
        let conversationHistory = [
            {
                role: "system",
                content: "Ou se yon asistan entelijan ki reponn an Kreyòl Ayisyen, Franse, oswa Anglè selon lang itilizatè a. Ede elèv yo konprann modil yo, bay eksplikasyon detaye sou teknoloji, devlopman, epi ou ka générer kòd HTML, CSS, JavaScript sou demann. Repons ou dwe klè, itil, ak amikal."
            }
        ];
        
        function loadConversation() {
            const saved = localStorage.getItem(STORAGE_KEY);
            if (saved) {
                try {
                    const parsed = JSON.parse(saved);
                    if (Array.isArray(parsed) && parsed.length > 0) {
                        conversationHistory = parsed;
                        chatMessagesDiv.innerHTML = '';
                        parsed.forEach(msg => {
                            if (msg.role === 'user') addMessageToUI(msg.content, 'user');
                            else if (msg.role === 'assistant') addMessageToUI(msg.content, 'bot');
                        });
                        if (chatMessagesDiv.children.length === 0) {
                            addMessageToUI("Bonjou! Mwen se asistan CEG. M ka ede w ak tout kesyon akademik, teknik, eksplikasyon modil, ak plis ankò. M ka générer kòd HTML, CSS, JavaScript rapidman. Kisa w bezwen?", 'bot');
                        }
                        return;
                    }
                } catch(e) {}
            }
            addMessageToUI("Bonjou! Mwen se asistan CEG. M ka ede w ak tout kesyon akademik, teknik, eksplikasyon modil, ak plis ankò. M ka générer kòd HTML, CSS, JavaScript rapidman. Kisa w bezwen?", 'bot');
        }
        
        function saveConversation() {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(conversationHistory));
        }
        
        function addMessageToUI(text, sender) {
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${sender === 'user' ? 'user-message' : 'bot-message'}`;
            const formattedText = text.replace(/\n/g, '<br>').replace(/```(\w*)\n([\s\S]*?)```/g, '<pre style="background:#0a0f1a; padding:8px; border-radius:8px; overflow-x:auto; font-size:0.75rem; margin:5px 0;"><code>$2</code></pre>');
            if (sender === 'bot') {
                messageDiv.innerHTML = `<i class="fas fa-robot" style="margin-right: 6px;"></i> ${formattedText}`;
            } else {
                messageDiv.innerHTML = `<i class="fas fa-user" style="margin-right: 6px;"></i> ${formattedText}`;
            }
            chatMessagesDiv.appendChild(messageDiv);
            chatMessagesDiv.scrollTop = chatMessagesDiv.scrollHeight;
        }
        
        function showTyping() {
            const typingDiv = document.createElement('div');
            typingDiv.className = 'typing-indicator';
            typingDiv.id = 'typingIndicator';
            typingDiv.innerHTML = `<span></span><span></span><span></span><span style="margin-left: 8px; font-size: 0.75rem;">Asistan ap ekri...</span>`;
            chatMessagesDiv.appendChild(typingDiv);
            chatMessagesDiv.scrollTop = chatMessagesDiv.scrollHeight;
        }
        
        function hideTyping() {
            const typing = document.getElementById('typingIndicator');
            if (typing) typing.remove();
        }
        
        async function callFirebaseAI(userMessage, history) {
            try {
                // Sauvegarder le message utilisateur dans Firebase
                const messagesRef = ref(database, 'chat_messages');
                const newMessageRef = push(messagesRef);
                await set(newMessageRef, {
                    userMessage: userMessage,
                    timestamp: Date.now(),
                    history: history.slice(-10)
                });
                
                // Ici nous allons appeler une Cloud Function.
                // Pour l'instant, on retourne une réponse simulée
                // Pour l'intégration IA, nous allons déployer une Cloud Function Firebase
                return `🤖 Repons CEG: "${userMessage.substring(0, 80)}..."\n\n📱 Mwen se asistan CEG. M la pou ede w ak tout kesyon ou yo sou teknoloji, devlopman web, ak òganizasyon pwojè.\n\n❓ Kisa w vle aprann jodi a?`;
            } catch (error) {
                console.error('Firebase error:', error);
                throw error;
            }
        }
        
        async function sendToAI(userMessage) {
            conversationHistory.push({ role: "user", content: userMessage });
            addMessageToUI(userMessage, 'user');
            saveConversation();
            showTyping();
            
            const historyToSend = conversationHistory.slice(-25);
            
            try {
                const botResponse = await callFirebaseAI(userMessage, historyToSend);
                
                conversationHistory.push({ role: "assistant", content: botResponse });
                addMessageToUI(botResponse, 'bot');
                saveConversation();
            } catch (error) {
                console.error('Error:', error);
                hideTyping();
                addMessageToUI("❌ Erè koneksyon.💡 Si pwoblèm nan kontinye, sa vle di nou poko gen vèsyon peyan firebase la klike sou 'Asistan altènatif' pou jwenn asistans dirèk.", 'bot');
            } finally {
                hideTyping();
            }
        }
        
        async function handleUserMessage() {
            const message = userInput.value.trim();
            if (!message) return;
            userInput.value = '';
            await sendToAI(message);
        }
        
        function clearConversation() {
            conversationHistory = [
                {
                    role: "system",
                    content: "Ou se yon asistan entelijan ki reponn an Kreyòl Ayisyen, Franse, oswa Anglè selon lang itilizatè a. Ede elèv yo konprann modil yo, bay eksplikasyon detaye sou teknoloji, devlopman, epi ou ka générer kòd HTML, CSS, JavaScript sou demann. Repons ou dwe klè, itil, ak amikal."
                }
            ];
            chatMessagesDiv.innerHTML = '';
            addMessageToUI("Konvèsasyon an te efase. Kijan m ka ede w jodi a? 🤖", 'bot');
            saveConversation();
        }
        
        // Évènements
        openBtn.addEventListener('click', () => {
            modal.classList.add('active');
            setTimeout(() => userInput.focus(), 100);
            loadConversation();
        });
        closeBtn.addEventListener('click', () => modal.classList.remove('active'));
        modal.addEventListener('click', (e) => {
            if (e.target === modal) modal.classList.remove('active');
        });
        sendBtn.addEventListener('click', handleUserMessage);
        userInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') handleUserMessage();
        });
        clearChatModalBtn.addEventListener('click', clearConversation);
        
        loadConversation();
        
        // === CANVAS ANIMATION ===
        const canvas = document.getElementById('bg-canvas');
        const ctx = canvas.getContext('2d');
        let width, height;
        let particles = [];
        const PARTICLE_COUNT = 180;
        let stars = [];
        const STAR_COUNT = 300;
        
        function resizeCanvas() {
            width = window.innerWidth;
            height = window.innerHeight;
            canvas.width = width;
            canvas.height = height;
            initParticles();
            initStars();
        }
        
        function initParticles() {
            particles = [];
            for (let i = 0; i < PARTICLE_COUNT; i++) {
                particles.push({
                    x: Math.random() * width,
                    y: Math.random() * height,
                    radius: Math.random() * 3 + 1.2,
                    alpha: Math.random() * 0.5 + 0.2,
                    speedX: (Math.random() - 0.5) * 0.25,
                    speedY: (Math.random() - 0.5) * 0.18,
                    color: `hsl(${Math.random() * 60 + 160}, 80%, 65%)`
                });
            }
        }
        
        function initStars() {
            stars = [];
            for (let i = 0; i < STAR_COUNT; i++) {
                stars.push({
                    x: Math.random() * width,
                    y: Math.random() * height,
                    radius: Math.random() * 2.2,
                    twinkle: Math.random() * 0.8 + 0.3,
                    speedTwinkle: 0.01 + Math.random() * 0.02,
                    angle: Math.random() * Math.PI * 2
                });
            }
        }
        
        function drawParticles() {
            for (let p of particles) {
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                ctx.fillStyle = p.color;
                ctx.shadowBlur = 8;
                ctx.shadowColor = "#0af";
                ctx.fill();
                p.x += p.speedX;
                p.y += p.speedY;
                if (p.x < -10) p.x = width + 10;
                if (p.x > width + 10) p.x = -10;
                if (p.y < -10) p.y = height + 10;
                if (p.y > height + 10) p.y = -10;
            }
            ctx.shadowBlur = 0;
        }
        
        function drawStars() {
            for (let s of stars) {
                const brightness = 0.4 + 0.6 * (Math.sin(Date.now() * s.speedTwinkle + s.angle) * 0.5 + 0.5);
                ctx.beginPath();
                ctx.arc(s.x, s.y, s.radius, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255, 240, 200, ${brightness * 0.9})`;
                ctx.fill();
            }
        }
        
        function drawNebula() {
            const time = Date.now() * 0.001;
            const grad = ctx.createRadialGradient(width*0.3 + Math.sin(time*0.2)*40, height*0.7 + Math.cos(time*0.3)*30, 40, width*0.4, height*0.6, 250);
            grad.addColorStop(0, 'rgba(0, 180, 210, 0.12)');
            grad.addColorStop(1, 'rgba(20, 30, 70, 0)');
            ctx.fillStyle = grad;
            ctx.fillRect(0, 0, width, height);
            
            const grad2 = ctx.createRadialGradient(width*0.8 + Math.sin(time*0.5)*50, height*0.2 + Math.cos(time*0.4)*40, 30, width*0.7, height*0.3, 300);
            grad2.addColorStop(0, 'rgba(150, 0, 255, 0.1)');
            grad2.addColorStop(1, 'rgba(0,0,0,0)');
            ctx.fillStyle = grad2;
            ctx.fillRect(0, 0, width, height);
        }
        
        function drawTechGrid() {
            const step = 55;
            ctx.beginPath();
            ctx.lineWidth = 0.6;
            ctx.strokeStyle = 'rgba(0, 200, 255, 0.18)';
            for (let x = 0; x < width; x += step) {
                ctx.beginPath();
                ctx.moveTo(x, 0);
                ctx.lineTo(x, height);
                ctx.stroke();
            }
            for (let y = 0; y < height; y += step) {
                ctx.beginPath();
                ctx.moveTo(0, y);
                ctx.lineTo(width, y);
                ctx.stroke();
            }
            ctx.beginPath();
            ctx.arc(width * 0.85, height * 0.15, 70, 0, Math.PI * 2);
            ctx.strokeStyle = 'rgba(0, 255, 210, 0.3)';
            ctx.lineWidth = 1.2;
            ctx.stroke();
            ctx.beginPath();
            ctx.arc(width * 0.12, height * 0.88, 110, 0, Math.PI * 2);
            ctx.stroke();
        }
        
        let frame = 0;
        function animate() {
            if (!ctx) return;
            ctx.clearRect(0, 0, width, height);
            const gradBg = ctx.createLinearGradient(0, 0, width, height);
            gradBg.addColorStop(0, '#020617');
            gradBg.addColorStop(1, '#050b1a');
            ctx.fillStyle = gradBg;
            ctx.fillRect(0, 0, width, height);
            
            drawStars();
            drawNebula();
            drawParticles();
            drawTechGrid();
            
            for (let i = 0; i < 12; i++) {
                const t = Date.now() * 0.001 + i;
                const x = width * (0.2 + 0.6 * Math.sin(t * 0.27));
                const y = height * (0.3 + 0.5 * Math.cos(t * 0.33));
                ctx.beginPath();
                ctx.arc(x, y, 15 + Math.sin(t * 3) * 5, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(0, 200, 255, ${0.1 + Math.sin(t) * 0.04})`;
                ctx.fill();
            }
            
            const glowX = width/2 + Math.sin(frame * 0.02) * 30;
            const glowY = height/2 + Math.cos(frame * 0.023) * 20;
            ctx.shadowBlur = 18;
            ctx.beginPath();
            ctx.arc(glowX, glowY, 70, 0, Math.PI*2);
            ctx.fillStyle = 'rgba(0, 180, 210, 0.05)';
            ctx.fill();
            ctx.shadowBlur = 0;
            
            frame++;
            requestAnimationFrame(animate);
        }
        
        window.addEventListener('resize', () => {
            resizeCanvas();
        });
        resizeCanvas();
        animate();
        
        // Animation stickers
        const stickers = document.querySelectorAll('.floating-sticker');
        if(stickers.length) {
            setInterval(() => {
                stickers.forEach((st, idx) => {
                    let moveX = (Math.sin(Date.now() * 0.002 + idx) * 6).toFixed(1);
                    let moveY = (Math.cos(Date.now() * 0.0025 + idx) * 5).toFixed(1);
                    st.style.transform = `translate(${moveX}px, ${moveY}px)`;
                });
            }, 100);
        }
        
        const btns = document.querySelectorAll('.neon-btn a');
        btns.forEach(btn => {
            btn.setAttribute('rel', 'noopener noreferrer');
        });
    </script>
