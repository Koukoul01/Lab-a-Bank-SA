    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Space Grotesk', sans-serif;
            background: #0a0c12;
            color: #eef5ff;
            overflow-x: hidden;
            line-height: 1.5;
        }

        /* --- CANVAS BACKGROUND PARTICULES / NEON FIRMAMENT --- */
        #bg-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
            background: radial-gradient(circle at 20% 30%, #05070c, #000000);
        }

        /* watermark stylisé (filigrane dynamique) */
        .watermark {
            position: fixed;
            bottom: 20px;
            right: 25px;
            z-index: 2;
            opacity: 0.2;
            pointer-events: none;
            font-family: 'Space Grotesk', monospace;
            font-weight: 800;
            font-size: 5rem;
            color: cyan;
            text-transform: uppercase;
            white-space: nowrap;
            transform: rotate(-8deg) scaleX(0.9);
            letter-spacing: 8px;
            filter: blur(1.2px);
            text-shadow: 0 0 15px rgba(0,255,255,0.5);
            transition: opacity 0.5s ease;
        }

        @media (max-width: 768px) {
            .watermark { font-size: 2.2rem; opacity: 0.12; bottom: 12px; right: 12px; }
        }

        /* GLASS / TRANSPARENCE PRINCIPALE */
        .glass-panel {
            background: rgba(15, 25, 45, 0.38);
            backdrop-filter: blur(14px) saturate(180%);
            border-radius: 2rem;
            border: 1px solid rgba(0, 255, 255, 0.25);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4), 0 0 20px rgba(0,255,255,0.1);
            transition: transform 0.3s ease, border-color 0.2s;
        }

        .glass-panel:hover {
            border-color: rgba(0, 255, 255, 0.6);
            box-shadow: 0 25px 45px rgba(0,0,0,0.5), 0 0 25px rgba(0,255,255,0.2);
        }

        /* conteneur principal */
        .container {
            position: relative;
            z-index: 5;
            max-width: 1350px;
            margin: 0 auto;
            padding: 2rem 2rem 4rem;
        }

        /* HEADER avec logo et titre neon */
        .hero {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            margin-bottom: 2rem;
        }

        .logo-wrapper {
            background: rgba(0,0,0,0.4);
            backdrop-filter: blur(8px);
            border-radius: 3rem;
            padding: 0.5rem 1.8rem;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(0,255,200,0.5);
            transition: all 0.4s;
        }
        .logo-wrapper img {
            max-width: 180px;
            height: auto;
            filter: drop-shadow(0 0 12px cyan);
            transition: transform 0.3s;
        }
        .logo-wrapper:hover img {
            transform: scale(1.02);
        }

        h1 {
            font-size: 4.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, #FFFFFF, #88f7ff, #0cf);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            text-shadow: 0 0 12px rgba(0,255,255,0.3);
            letter-spacing: -0.02em;
            margin-bottom: 0.5rem;
        }
        .sub {
            font-size: 1.3rem;
            font-weight: 400;
            letter-spacing: 1px;
            color: #b4f0ff;
            text-shadow: 0 0 5px #0af;
        }

        /* Bannière d'information test */
        .test-banner {
            background: rgba(0, 20, 40, 0.7);
            backdrop-filter: blur(12px);
            border-radius: 2rem;
            border: 1px solid rgba(0, 255, 200, 0.5);
            padding: 1rem 1.8rem;
            margin: 1rem auto 2rem auto;
            display: inline-flex;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
            justify-content: center;
            font-size: 0.95rem;
            font-weight: 500;
            color: #ccf4ff;
            box-shadow: 0 0 12px rgba(0,255,255,0.2);
        }
        .test-banner i {
            font-size: 1.4rem;
            color: #0cf;
        }
        .test-banner strong {
            color: white;
            font-weight: 700;
            background: rgba(0,255,255,0.2);
            padding: 0.2rem 0.6rem;
            border-radius: 40px;
            font-family: monospace;
        }

        /* Boutons en haut */
        .top-button-wrapper {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            margin: 1rem 0 1.5rem 0;
            flex-wrap: wrap;
        }
        .neon-btn {
            position: relative;
            background: rgba(0, 20, 40, 0.7);
            backdrop-filter: blur(12px);
            border: 1.5px solid rgba(0, 255, 255, 0.8);
            padding: 0.9rem 2rem;
            min-width: 240px;
            font-size: 1.3rem;
            font-weight: 700;
            font-family: 'Space Grotesk', monospace;
            color: #eef5ff;
            border-radius: 60px;
            cursor: pointer;
            transition: 0.25s;
            text-align: center;
            letter-spacing: 1px;
            box-shadow: 0 0 12px rgba(0, 255, 255, 0.4);
            overflow: hidden;
            z-index: 2;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-decoration: none;
        }
        .neon-btn a {
            text-decoration: none;
            color: inherit;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .neon-btn::before {
            content: "";
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 255, 255, 0.4), transparent);
            transition: left 0.6s ease;
        }
        .neon-btn:hover::before {
            left: 100%;
        }
        .neon-btn:hover {
            background: rgba(0, 255, 255, 0.2);
            border-color: #0cf;
            box-shadow: 0 0 28px cyan, 0 0 10px cyan;
            transform: scale(1.02);
            color: white;
        }

        /* MODAL ASSISTANT */
        .ai-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(12px);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }
        .ai-modal.active {
            display: flex;
        }
        .ai-modal-content {
            width: 90%;
            max-width: 550px;
            height: 80vh;
            background: linear-gradient(145deg, #0a1022, #0c1328);
            border-radius: 2rem;
            border: 1px solid rgba(0, 255, 255, 0.5);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }
        .ai-modal-header {
            background: linear-gradient(90deg, #0f212e, #0a1a2a);
            padding: 1rem 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(0, 255, 200, 0.5);
        }
        .ai-modal-header h2 {
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #7dd3fc;
        }
        .close-modal {
            background: rgba(255, 100, 100, 0.2);
            border: 1px solid #ff6666;
            color: #ff8888;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .close-modal:hover {
            background: #ff4444;
            color: white;
        }
        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 1.2rem;
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
            background: rgba(0, 0, 0, 0.3);
        }
        .message {
            max-width: 85%;
            padding: 0.8rem 1.2rem;
            border-radius: 1.2rem;
            word-wrap: break-word;
            line-height: 1.4;
            font-size: 0.9rem;
        }
        .user-message {
            background: linear-gradient(135deg, #10b981, #059669);
            align-self: flex-end;
            color: white;
            border-bottom-right-radius: 0.3rem;
        }
        .bot-message {
            background: rgba(30, 42, 68, 0.95);
            align-self: flex-start;
            color: #e2e8f0;
            border-bottom-left-radius: 0.3rem;
            border-left: 3px solid #22d3ee;
        }
        .typing-indicator {
            background: rgba(30, 42, 68, 0.95);
            align-self: flex-start;
            padding: 0.8rem 1.2rem;
            border-radius: 1.2rem;
            display: flex;
            gap: 5px;
            align-items: center;
        }
        .typing-indicator span {
            width: 7px;
            height: 7px;
            background: #22d3ee;
            border-radius: 50%;
            animation: bounce 1.4s infinite ease-in-out;
        }
        .typing-indicator span:nth-child(1) { animation-delay: 0s; }
        .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
        .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
        @keyframes bounce {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-6px); }
        }
        .input-area {
            display: flex;
            gap: 0.8rem;
            padding: 1rem;
            background: rgba(0, 0, 0, 0.4);
            border-top: 1px solid rgba(0, 255, 200, 0.2);
            flex-wrap: wrap;
        }
        .input-area input {
            flex: 1;
            min-width: 150px;
            padding: 0.8rem 1.2rem;
            background: #1e2a44;
            border: 1px solid #3b5a9c;
            border-radius: 2rem;
            color: white;
            font-size: 0.9rem;
            outline: none;
        }
        .input-area input:focus {
            border-color: #22d3ee;
        }
        .input-area button {
            background: linear-gradient(135deg, #22d3ee, #0891b2);
            border: none;
            padding: 0.8rem 1.5rem;
            border-radius: 2rem;
            color: white;
            font-weight: bold;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: 0.2s;
            white-space: nowrap;
        }
        .input-area button:active {
            transform: scale(0.97);
        }
        @media (max-width: 480px) {
            .input-area {
                padding: 0.8rem;
                gap: 0.5rem;
            }
            .input-area input {
                min-width: 120px;
                padding: 0.7rem 1rem;
                font-size: 0.85rem;
            }
            .input-area button {
                padding: 0.7rem 1rem;
                font-size: 0.85rem;
            }
        }
        .modal-footer {
            background: #07161f;
            padding: 0.7rem 1rem;
            display: flex;
            justify-content: center;
            gap: 1rem;
            flex-wrap: wrap;
            font-size: 0.7rem;
            color: #5c9eb0;
        }
        .clear-chat, .alternative-link {
            background: transparent;
            border: 1px solid #ef4444;
            color: #ef4444;
            padding: 0.3rem 1rem;
            border-radius: 2rem;
            cursor: pointer;
            font-size: 0.7rem;
            transition: 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        .alternative-link {
            border-color: #22d3ee;
            color: #22d3ee;
        }
        .alternative-link:hover, .clear-chat:hover {
            opacity: 0.8;
            transform: scale(1.02);
        }
        ::-webkit-scrollbar {
            width: 5px;
        }
        ::-webkit-scrollbar-track {
            background: #0f1a30;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #22d3ee;
            border-radius: 10px;
        }

        /* carte présentation */
        .description-card {
            padding: 2rem;
            margin-bottom: 2.5rem;
            transition: all 0.25s;
        }
        .mission-text {
            font-size: 1.6rem;
            font-weight: 700;
            color: #e0fcff;
            border-left: 4px solid #0cf;
            padding-left: 1.2rem;
            margin: 1rem 0;
        }
        .highlight {
            background: linear-gradient(120deg, rgba(0,255,255,0.2), transparent);
            padding: 0.2rem 0.4rem;
            border-radius: 12px;
            font-weight: 600;
        }
        .grid-info {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.8rem;
            margin: 2.5rem 0;
        }
        .info-item {
            background: rgba(10, 20, 35, 0.55);
            backdrop-filter: blur(6px);
            border-radius: 1.5rem;
            padding: 1.5rem;
            border: 1px solid rgba(0, 255, 255, 0.3);
            transition: all 0.3s;
        }
        .info-item i {
            font-size: 2.2rem;
            color: #0cf;
            margin-bottom: 1rem;
        }
        .info-item h3 {
            font-size: 1.6rem;
            margin-bottom: 0.75rem;
            font-weight: 600;
        }
        .director-block {
            display: flex;
            flex-wrap: wrap;
            gap: 2rem;
            justify-content: space-between;
            background: rgba(0, 0, 0, 0.45);
            backdrop-filter: blur(12px);
            border-radius: 2rem;
            padding: 1.5rem 2rem;
            margin-top: 1.5rem;
            border: 1px solid rgba(0, 255, 255, 0.4);
        }
        .director {
            flex: 1;
        }
        .director .name {
            font-size: 1.3rem;
            font-weight: 700;
            color: #0cf;
        }
        .director .title {
            font-size: 0.9rem;
            color: #b4f0ff;
            margin-top: 0.3rem;
        }
        .director .skills {
            font-size: 0.8rem;
            color: #8bb4d0;
            margin-top: 0.5rem;
            line-height: 1.4;
        }

        /* SECTION FORMATION AVEC DÉTAILS PÉDAGOGIQUES */
        .formation-panel {
            padding: 2rem;
            margin-bottom: 2.5rem;
        }
        .formation-panel h2 {
            font-size: 2rem;
            margin-bottom: 1.2rem;
            display: flex;
            align-items: center;
            gap: 12px;
            border-left: 4px solid #0cf;
            padding-left: 1rem;
        }
        .formation-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
            margin-top: 1.5rem;
        }
        .formation-card {
            background: rgba(0, 20, 40, 0.5);
            backdrop-filter: blur(5px);
            border-radius: 1.2rem;
            padding: 1.2rem;
            border: 1px solid rgba(0, 200, 255, 0.3);
            transition: 0.2s;
        }
        .formation-card i {
            font-size: 1.8rem;
            color: #0cf;
            margin-right: 10px;
        }
        .formation-card strong {
            font-size: 1.2rem;
            color: #b5f0ff;
        }
        .festival-note {
            background: linear-gradient(135deg, rgba(0,255,200,0.15), rgba(0,100,150,0.2));
            border-radius: 1.5rem;
            padding: 1.2rem;
            margin-top: 1.8rem;
            text-align: center;
            font-weight: 500;
            border: 1px dashed #0cf;
        }

        /* SECTION MÉTHODOLOGIE MOBILE */
        .methodology-section {
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            background: rgba(0, 30, 50, 0.5);
            border-radius: 1.5rem;
            border: 1px solid rgba(0, 255, 200, 0.3);
        }
        .methodology-section h3 {
            font-size: 1.4rem;
            color: #0cf;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .methodology-section p {
            font-size: 1rem;
            line-height: 1.6;
            margin-bottom: 1rem;
        }
        .method-list {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1rem;
            margin: 1rem 0;
        }
        .method-item {
            background: rgba(0, 0, 0, 0.3);
            padding: 0.8rem;
            border-radius: 1rem;
            border-left: 3px solid #0cf;
        }
        .method-item i {
            color: #0cf;
            margin-right: 8px;
        }

        .small-note {
            text-align: center;
            margin-top: 1.2rem;
            font-size: 0.85rem;
            opacity: 0.8;
        }
        footer {
            text-align: center;
            margin-top: 3rem;
            font-size: 0.85rem;
            opacity: 0.7;
            border-top: 1px solid rgba(0,255,255,0.2);
            padding-top: 2rem;
        }
        .glow-text {
            text-shadow: 0 0 4px cyan;
        }

        @media (max-width: 780px) {
            h1 { font-size: 2.8rem; }
            .container { padding: 1rem; }
            .mission-text { font-size: 1.2rem; }
            .formation-panel h2 { font-size: 1.5rem; }
            .neon-btn { min-width: 200px; font-size: 1.1rem; padding: 0.7rem 1rem; }
            .test-banner { font-size: 0.8rem; padding: 0.7rem 1.2rem; }
        }
        p, li {
            font-size: 1.05rem;
            color: #deedff;
        }
        a {
            text-decoration: none;
        }
        
        @keyframes morph {
            0% { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; transform: rotate(0deg) translateY(0px);}
            50% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; transform: rotate(10deg) translateY(-12px);}
            100% { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; transform: rotate(0deg) translateY(0px);}
        }
        .sticker-bg .floating-sticker {
            animation: morph 8s infinite ease-in-out;
        }
    </style>
</head>
<body>

    <canvas id="bg-canvas"></canvas>
    <div class="watermark">CEG</div>
    
    <!-- Stickers flottants (décor) -->
    <div class="sticker-bg" style="position: fixed; bottom: 8%; left: 2%; width: 100px; height: 100px; pointer-events: none; z-index: 3; opacity: 0.6;">
